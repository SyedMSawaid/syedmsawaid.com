---
layout: default
---
<header class="mb-10">
  <h1 class="text-2xl font-semibold tracking-tight text-slate-900 leading-tight mb-3">{{ data.title }}</h1>
  <div class="flex items-center gap-2 text-xs text-slate-400 uppercase tracking-wider">
    <time>{{ data.date | date: '%B %d, %Y' }}</time>
    <span>·</span>
    <span>{{ page.content | reading_time }} min read</span>
  </div>
</header>

<div class="prose">{{ content }}</div>

<nav class="mt-16 pt-8 border-t border-slate-100 grid grid-cols-2 gap-8">
  <div>
    {% if page.previous %}
      <a href="{{ page.previous.relative_url }}" class="group block" style="text-decoration:none">
        <span class="text-xs font-medium uppercase tracking-widest text-slate-400 group-hover:text-slate-900 transition-colors duration-150">Previous</span>
        <p class="text-sm text-slate-800 group-hover:text-slate-500 transition-colors duration-150 mt-1 mb-0 leading-snug">{{ page.previous.data.title }}</p>
      </a>
    {% endif %}
  </div>
  <div class="text-right">
    {% if page.next %}
      <a href="{{ page.next.relative_url }}" class="group block" style="text-decoration:none">
        <span class="text-xs font-medium uppercase tracking-widest text-slate-400 group-hover:text-slate-900 transition-colors duration-150">Next</span>
        <p class="text-sm text-slate-800 group-hover:text-slate-500 transition-colors duration-150 mt-1 mb-0 leading-snug">{{ page.next.data.title }}</p>
      </a>
    {% endif %}
  </div>
</nav>
