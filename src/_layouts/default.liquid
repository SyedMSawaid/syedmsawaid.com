<!doctype html>
<html lang="{{ site.locale }}">
  <head>
    {% render 'analytics' %}
    {% render 'head', metadata: site.metadata, title: data.title %}
    {% feed_meta %}
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    {% render 'no_script' %}

    <div class="max-w-[640px] w-full mx-auto px-5 sm:px-8 py-10 sm:py-14 flex flex-col flex-1">
      {% render 'navbar', metadata: site.metadata, resource: resource %}

      <main class="mt-14 flex-1">
        {{ content }}
      </main>

      {% render 'footer', metadata: site.metadata %}
    </div>
  </body>
</html>
