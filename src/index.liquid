---
layout: default
---

<div class="mb-14">
  <h1 class="text-xl font-semibold tracking-tight text-slate-900 mb-3">Syed Muhammad Sawaid</h1>
  <p class="text-slate-500 text-sm leading-relaxed m-0">
    Software engineer and filmmaker based in Marburg, Germany. Doing a Masters in Data Science at Philipps University Marburg, working at BayWa r.e. I write about software, life in Germany, and whatever catches my attention.
  </p>
</div>

<section class="mb-12">
  <h2 class="text-xs font-medium uppercase tracking-widest text-slate-400 mb-5">Writing</h2>
  <div class="flex flex-col">
    {% for post in collections.posts.resources limit:5 %}
    <a href="{{ post.relative_url }}" class="flex items-baseline justify-between gap-6 py-2.5 border-b border-slate-100 last:border-0 group">
      <span class="text-sm text-slate-800 group-hover:text-slate-500 transition-colors duration-150 truncate">{{ post.title }}</span>
      <time class="text-xs text-slate-400 shrink-0">{{ post.data.date | date: '%b %Y' }}</time>
    </a>
    {% endfor %}
  </div>
  <a href="/posts" class="mt-4 inline-block text-xs text-slate-400 hover:text-slate-900 transition-colors duration-150">All writing →</a>
</section>

<section class="mb-12">
  <h2 class="text-xs font-medium uppercase tracking-widest text-slate-400 mb-5">Software</h2>
  <div class="flex flex-col">
    {% for project in collections.software.resources %}
    <a href="{{ project.relative_url }}" class="flex items-baseline justify-between gap-6 py-2.5 border-b border-slate-100 last:border-0 group">
      <span class="text-sm text-slate-800 group-hover:text-slate-500 transition-colors duration-150">{{ project.data.title }}</span>
      <span class="text-xs text-slate-400 shrink-0">{{ project.data.type }}</span>
    </a>
    {% endfor %}
  </div>
  <a href="/software" class="mt-4 inline-block text-xs text-slate-400 hover:text-slate-900 transition-colors duration-150">All projects →</a>
</section>

<section>
  <h2 class="text-xs font-medium uppercase tracking-widest text-slate-400 mb-5">Get in touch</h2>
  <div class="flex flex-col gap-1.5">
    <a href="mailto:hi@syedmsawaid.com" class="text-sm text-slate-700 hover:text-slate-400 transition-colors duration-150">hi@syedmsawaid.com</a>
    <a href="https://x.com/syedmsawaid" target="_blank" rel="noopener" class="text-sm text-slate-700 hover:text-slate-400 transition-colors duration-150">@syedmsawaid on X</a>
  </div>
</section>
