---
layout: page
title: Archive
---
{% assign sorted_posts = collections.posts.resources | sort: 'date' | reverse %}
{% assign current_year = '' %}
{% for post in sorted_posts %}
  {% assign post_year = post.data.date | date: '%Y' %}
  {% if current_year != post_year %}
    {% unless current_year == '' %}</div></div>{% endunless %}
    {% assign current_year = post_year %}
    <div class="mb-10">
      <h2 class="text-xs font-medium uppercase tracking-widest text-slate-400 mb-4">{{ post_year }}</h2>
      <div class="flex flex-col">
  {% endif %}
    <a href="{{ post.relative_url }}" class="flex items-baseline justify-between gap-6 py-2.5 border-b border-slate-100 group" style="text-decoration:none">
      <span class="text-sm text-slate-800 group-hover:text-slate-500 transition-colors duration-150">{{ post.data.title }}</span>
      <time class="text-xs text-slate-400 shrink-0">{{ post.data.date | date: '%b %d' }}</time>
    </a>
{% endfor %}
{% if sorted_posts.size > 0 %}</div></div>{% endif %}
